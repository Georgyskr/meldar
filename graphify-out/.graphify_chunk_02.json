    {
      "id": "option_a_pure_r2",
      "type": "concept",
      "label": "Option A: Pure Cloudflare R2 Storage",
      "properties": {
        "description": "R2 list/get/put as only file API, Postgres holds only user/project/billing metadata",
        "status": "Rejected"
      }
    },
    {
      "id": "option_b_hybrid",
      "type": "concept",
      "label": "Option B: Postgres Manifest + R2 Content Hybrid",
      "properties": {
        "description": "Postgres manifest (jsonb or normalized) tracks files, R2 stores content blobs",
        "status": "Superseded by Option C"
      }
    },
    {
      "id": "option_c_event_sourced",
      "type": "concept",
      "label": "Option C: Event-Sourced Build Log + Content-Addressed R2",
      "properties": {
        "description": "Postgres event log (builds + build_files rows) + R2 content at content-addressed keys (sha256). Build is the unit of truth.",
        "schema_tables": ["projects", "builds", "build_files"],
        "r2_layout": "projects/{projectId}/content/{contentHash}",
        "status": "Selected"
      }
    },
    {
      "id": "content_addressing",
      "type": "concept",
      "label": "Content-Addressed Storage (SHA-256)",
      "properties": {
        "benefits": ["free dedup", "free integrity", "free immutability", "free rollback"],
        "key_pattern": "projects/{projectId}/blobs/{sha256}"
      }
    },
    {
      "id": "build_as_unit_of_truth",
      "type": "rationale",
      "label": "Build Is the Unit of Truth, Not the File",
      "properties": {
        "reasoning": "Files are payload of build events. Build is a causally-traceable event with producer (Sonnet), consumer (sandbox), and payload (file set). Optimizing for the event unlocks undo/redo, A/B testing, diffs, snapshots, forks.",
        "source": "Data Engineer + Software Architect reviews"
      }
    },
    {
      "id": "github_phase2_migration",
      "type": "concept",
      "label": "GitHub Phase-2 Migration Path",
      "properties": {
        "description": "Each Build maps to a git commit. build_files = tree entries. Content-addressed blobs = git blobs. Option C maps naturally.",
        "estimated_effort": "~1 week from Option C vs ~3 weeks from Option A"
      }
    },
