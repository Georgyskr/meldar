{
	"name": "@meldar/db",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "Drizzle ORM schema, client factory, and migrations for Meldar's Postgres (Neon) database.",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./client": "./src/client.ts",
		"./schema": "./src/schema.ts"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:generate": "drizzle-kit generate"
	},
	"dependencies": {
		"@neondatabase/serverless": "^1.0.2",
		"drizzle-orm": "^0.45.2"
	},
	"devDependencies": {
		"@meldar/tooling-config": "workspace:*",
		"@types/node": "^20",
		"dotenv": "^17.3.1",
		"drizzle-kit": "^0.31.10",
		"typescript": "^5"
	}
}
