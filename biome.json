{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "error",
				"useExhaustiveDependencies": "warn"
			},
			"style": {
				"noNonNullAssertion": "error",
				"useConsistentArrayType": {
					"level": "warn",
					"options": {
						"syntax": "shorthand"
					}
				}
			},
			"suspicious": {
				"noExplicitAny": "error"
			},
			"complexity": {
				"noImportantStyles": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded"
		}
	},
	"json": {
		"formatter": {
			"indentStyle": "tab"
		}
	},
	"files": {
		"includes": [
			"apps/*/src/**",
			"apps/*/e2e/**",
			"apps/*/*.ts",
			"apps/*/*.json",
			"packages/*/src/**",
			"packages/*/test/**",
			"packages/*/*.ts",
			"packages/*/*.json",
			"*.ts",
			"*.json",
			"!**/next-env.d.ts",
			"!**/.next",
			"!**/styled-system",
			"!**/node_modules",
			"!**/.turbo",
			"!**/dist",
			"!**/e2e/.auth",
			"!**/playwright-report",
			"!**/test-results"
		]
	}
}
